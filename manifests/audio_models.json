{
  "version": "1.0",
  "models": [
    {
      "model_id": "edge-tts",
      "provider": "microsoft",
      "kind": "audio",
      "name": "Microsoft Edge TTS",
      "input_slots": {
        "text": {"type": "string", "required": true, "description": "要合成的文本（中文）"},
        "voice": {"type": "string", "required": true, "description": "语音角色名"},
        "rate": {"type": "string", "default": "+0%", "description": "语速"},
        "pitch": {"type": "string", "default": "+0Hz", "description": "音调"}
      },
      "output": {
        "format": "wav",
        "default_voice_narrator": "zh-CN-YunyangNeural",
        "default_voice_dialogue": "zh-CN-XiaoxiaoNeural"
      },
      "pricing": {"type": "free"}
    }
  ]
}
